---
layout: default
---
{%- assign hero_tagline = page.hero_tagline | default: site.description -%}
{%- assign github_user = site.data.socials.github_username -%}

<!-- ━━━ Hero ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<section class="pf-hero" aria-label="소개">
  <div class="pf-hero__inner">

    <p class="pf-hero__eyebrow">Data Analyst</p>

    <h1 class="pf-hero__name">
      {%- if site.title == 'blank' -%}
        {%- if site.first_name -%}{{ site.first_name }}{%- endif -%}
        {%- if site.last_name %}{{ site.last_name }}{%- endif -%}
      {%- else -%}
        {{ site.title }}
      {%- endif -%}
    </h1>

    <p class="pf-hero__tagline">{{ hero_tagline }}</p>

    <div class="pf-hero__cta">
      <a href="{{ '/projects/' | relative_url }}" class="pf-btn pf-btn--primary">
        프로젝트 보기
      </a>
      <a href="{{ '/cv/' | relative_url }}" class="pf-btn pf-btn--ghost">
        CV
      </a>
      {%- if github_user -%}
      <a href="https://github.com/{{ github_user }}"
         target="_blank"
         rel="noopener noreferrer"
         class="pf-btn pf-btn--ghost">
        <i class="fab fa-github" aria-hidden="true"></i>&thinsp;GitHub
      </a>
      {%- endif -%}
      {%- if site.data.socials.email -%}
      <a href="mailto:{{ site.data.socials.email }}"
         class="pf-btn pf-btn--ghost">
        <i class="fas fa-envelope" aria-hidden="true"></i>&thinsp;이메일
      </a>
      {%- endif -%}
    </div>

  </div>

  <!-- 스크롤 유도 화살표 -->
  <div class="pf-scroll-indicator" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2"
         stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>
</section>

<!-- ━━━ Content ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<div class="pf-content-wrapper">
  <div class="pf-content">
    {{ content }}

    {%- if page.social -%}
    <div class="social mt-4 pt-1" style="border-top: 1px solid var(--pf-border);">
      <div class="contact-icons" style="margin-top: 1.2rem;">{% social_links %}</div>
    </div>
    {%- endif -%}
  </div>
</div>
