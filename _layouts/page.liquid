---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

  {% if page.collection == 'projects' %}
    {% if page.role or page.period or page.tags %}
      <div class="project-meta-bar mb-3">
        {% if page.role %}<span class="project-meta-badge"><i class="fa-solid fa-user-tie"></i> {{ page.role }}</span>{% endif %}
        {% if page.period %}<span class="project-meta-badge"><i class="fa-regular fa-calendar"></i> {{ page.period }}</span>{% endif %}
        {% for tag in page.tags %}<span class="project-meta-tag">{{ tag }}</span>{% endfor %}
      </div>
    {% endif %}
  {% endif %}

  {% if page.img and page.collection == 'projects' %}
    <div class="project-hero mb-4">
      {%
        include figure.liquid
        loading="eager"
        path=page.img
        alt=page.title
        class="project-hero-img"
      %}
    </div>
  {% endif %}

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}

  {% if page.collection == 'projects' %}
    {% assign all_projects = site.projects | sort: "importance" %}
    {% assign proj_count = all_projects | size %}
    {% assign prev_project = nil %}
    {% assign next_project = nil %}
    {% for proj in all_projects %}
      {% if proj.url == page.url %}
        {% assign curr_index = forloop.index0 %}
      {% endif %}
    {% endfor %}
    {% if curr_index and curr_index > 0 %}
      {% assign prev_index = curr_index | minus: 1 %}
      {% assign prev_project = all_projects[prev_index] %}
    {% endif %}
    {% assign next_index = curr_index | plus: 1 %}
    {% if next_index < proj_count %}
      {% assign next_project = all_projects[next_index] %}
    {% endif %}

    {% if prev_project or next_project %}
    <nav class="project-nav mt-5">
      <div class="project-nav-prev">
        {% if prev_project %}
          <a href="{{ prev_project.url | relative_url }}">
            <span class="project-nav-label"><i class="fa-solid fa-chevron-left"></i> 이전 프로젝트</span>
            <span class="project-nav-title">{{ prev_project.title }}</span>
          </a>
        {% endif %}
      </div>
      <div class="project-nav-next">
        {% if next_project %}
          <a href="{{ next_project.url | relative_url }}">
            <span class="project-nav-label">다음 프로젝트 <i class="fa-solid fa-chevron-right"></i></span>
            <span class="project-nav-title">{{ next_project.title }}</span>
          </a>
        {% endif %}
      </div>
    </nav>
    {% endif %}
  {% endif %}
</div>
