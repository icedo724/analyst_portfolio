<div class="col">
  <div class="card h-100 pf-project-card">
    <div class="card-body d-flex flex-column">

      <!-- Title + WIP badge -->
      <h5 class="card-title mb-2">
        {{ project.title }}
        {%- if project.wip -%}
          <span class="pf-badge-wip">진행 중</span>
        {%- endif -%}
      </h5>

      <!-- Description / Impact -->
      <p class="card-text flex-grow-1">{{ project.description }}</p>

      <!-- Tags -->
      {%- if project.tags -%}
        <div class="pf-tags mb-3">
          {%- for tag in project.tags -%}
            <span class="pf-tag">{{ tag }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <!-- Links (GitHub / 리포트 / 대시보드) -->
      {%- if project.links -%}
        <div class="project-links">
          {%- for link in project.links -%}
            <a href="{{ link.url }}"
               target="_blank"
               rel="noopener noreferrer"
               class="project-link-btn">
              <i class="{{ link.icon }}" aria-hidden="true"></i>{{ link.text }}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>
